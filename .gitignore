# Node.js .gitignore

# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
node_modules/

# Environment variable files
.env

# Next.js build output
.next/

# Build output
dist/
build/

# Mac system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db

# Linux system files
*~

# IDEs
.idea/
*.sublime-project
*.sublime-workspace
